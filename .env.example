# Required for eBook checkout + instant download
# Use your secret key from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Public site URL (no trailing slash). Used for Stripe redirects and blog link previews when shared on social.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Blog admin (/admin): one or more usernames with passwords, plus a session secret.
# Usernames are case-insensitive. Replace placeholder passwords before going live.
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_USERS={"omari":"placeholder-omari","dale":"placeholder-dale"}
ADMIN_SESSION_SECRET=replace-with-long-random-string

# Blog posts created in /admin are stored in private/blog-posts.json locally.
# On Vercel, the same store uses your Blob token (often already set for eBooks).
# BLOB_READ_WRITE_TOKEN=

# In src/data/books.json use stripePriceIdEbook = a Price ID (starts with price_),
# not a Product ID (prod_). Copy it from the product’s Pricing section in Stripe.

# eBook PDF on Vercel Blob (production): JSON map of book id → blob URL from the dashboard.
# Private blobs need BLOB_READ_WRITE_TOKEN (Vercel adds it when the project has a Blob store).
# Example: EBOOK_BLOB_URLS={"book-one":"https://xxxx.public.blob.vercel-storage.com/ebooks/sickle-cell.pdf","book-two":"https://xxxx.public.blob.vercel-storage.com/ebooks/word-search.pdf","book-three":"https://xxxx.public.blob.vercel-storage.com/ebooks/asthma.pdf"}
# EBOOK_BLOB_URLS=
# BLOB_READ_WRITE_TOKEN=
